{
  "name": "agentflow",
  "version": "0.1.0",
  "description": "A local CLI orchestrator for AI-assisted software development workflows.",
  "type": "module",
  "bin": {
    "agentflow": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "npm run build --silent && tsx --test test/*.test.ts"
  },
  "keywords": [
    "ai",
    "cli",
    "orchestration",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
